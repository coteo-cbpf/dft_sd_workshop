#!/bin/bash
set -euo pipefail

echo "Installing uppasd from TestPyPI (pre-release)..."
# Install the pre-release `uppasd` wheel from Test PyPI while keeping PyPI as fallback
pip install --pre --index-url https://test.pypi.org/simple/ --extra-index-url https://pypi.org/simple uppasd

echo "Done installing uppasd."
